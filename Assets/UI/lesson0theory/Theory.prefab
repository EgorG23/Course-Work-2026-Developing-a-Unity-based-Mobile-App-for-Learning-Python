  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u044F\u0437\u044B\u043A \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432\u044B\u0441\u043E\u043A\u043E\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F.
    \n\n\u0422\u043E \u0435\u0441\u0442\u044C \u0434\u043B\u044F \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u043A\u043E\u0434\u0430 \u043D\u0430 \u044D\u0442\u043E\u043C \u044F\u0437\u044B\u043A\u0435
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u044B\u0435
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438, \u0441\u0445\u043E\u0436\u0438\u0435
    \u0441\u043E \u0441\u043B\u043E\u0432\u0430\u043C\u0438 \u0438\u0437 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 (print, sum, remove \u0438 \u0442.\u0434.) "
