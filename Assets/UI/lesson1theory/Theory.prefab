  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412 Python \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043A\u043E\u043C\u0430\u043D\u0434. \n\r\n\u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    print(\u2026) \u0432\u044B\u0432\u043E\u0434\u0438\u0442 \u043D\u0430 \u044D\u043A\u0440\u0430\u043D
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435 \u0432\u043D\u0443\u0442\u0440\u0438
    \u0441\u043A\u043E\u0431\u043E\u043A. \r\n\u0422\u043E, \u0447\u0442\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0432\u043D\u0443\u0442\u0440\u0438 \u044D\u0442\u0438\u0445 \u0441\u043A\u043E\u0431\u043E\u043A,
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u0430\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C
    \u0441\u0442\u0440\u043E\u043A\u043E\u0439 (\u201CHello!\u201D), \u0447\u0438\u0441\u043B\u0430
    (67), \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 (user_name).\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 817a864758752c948b7c0c77c200ec46, type: 2}
