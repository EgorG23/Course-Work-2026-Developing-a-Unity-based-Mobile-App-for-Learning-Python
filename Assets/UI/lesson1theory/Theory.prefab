    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0422\u043E \u0435\u0441\u0442\u044C \u043F\u0440\u0438 \u0437\u0430\u043F\u0443\u0441\u043A\u0435
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B \u043E\u0436\u0438\u0434\u0430\u0435\u0442\u0441\u044F
    \u0432\u0432\u043E\u0434 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0441
    \u043A\u043B\u0430\u0432\u0438\u0430\u0442\u0443\u0440\u044B. \n\u0415\u0441\u043B\u0438
    \u0432\u0432\u0435\u0441\u0442\u0438 16, \u0442\u043E user_age = 16 (\u0447\u0438\u0441\u043B\u043E).
    \n\u0410 \u0435\u0441\u043B\u0438 \u0432\u0432\u0435\u0441\u0442\u0438 \xAB16\xBB,
    \u0442\u043E user_age = \u201C16\u201D (\u0441\u0442\u0440\u043E\u043A\u0430).
    \n\u041E\u0434\u043D\u0430\u043A\u043E, \u0435\u0441\u043B\u0438 \u0432\u0432\u0435\u0441\u0442\u0438
    \u0441\u043B\u043E\u0432\u043E \xABHSE\xBB (\u0431\u0435\u0437 \u043A\u0430\u0432\u044B\u0447\u0435\u043A),
    \u0442\u043E \u043E\u043D\u043E \u0432\u0441\u0451 \u0440\u0430\u0432\u043D\u043E
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043A\u0430\u043A \u0441\u0442\u0440\u043E\u043A\u0430."
