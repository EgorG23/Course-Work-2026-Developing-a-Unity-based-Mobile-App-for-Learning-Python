    \u041F\u0440\u043E\u0449\u0435 \u0433\u043E\u0432\u043E\u0440\u044F, \u0435\u0441\u043B\u0438
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0430
    \u0438\u0437 \u0431\u043E\u043B\u0435\u0435 \u0447\u0435\u043C 2 \u0432\u0435\u0442\u043E\u043A,
    \u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    else if:"
