  m_text: "2.\n\n\u0417\u0430\u0434\u0430\u043D\u0438\u0435 -  \u0434\u043E\u043F\u0438\u0441\u0430\u0442\u044C
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0435\u0442 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438: \n\nf = x^2 + 2x \u2013 19,    \u0433\u0434\u0435
    x = 5\xBB\n"
