  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412\u041D\u0418\u041C\u0410\u041D\u0418\u0415!\n\n\u041F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438 \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u043E\u0432
    \u0441\u043B\u043E\u043C\u0430\u043D\u0430. \u041D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
    \u0435\u0451  \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u0430\u0442\u044C, \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432
    \u0435\u0451 \u0444\u043E\u0440\u043C\u0430\u0442. \n\r\n\u041F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0442\u044C
    2 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 (ueer_name \u0438
    user_password), \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043F\u0440\u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442\u0441\u044F
    \u0432 \u0441\u0430\u043C\u043E\u043C \u043A\u043E\u0434\u0435 (\u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    a = 4). \u0418 \u044D\u0442\u0438 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u043F\u043E \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438 
    \u0432\u044B\u0432\u043E\u0434\u044F\u0442\u0441\u044F \u043D\u0430 \u044D\u043A\u0440\u0430\u043D. 
    \n\n\u0412\u0441\u0435\u0433\u043E \u0441\u0442\u0440\u043E\u043A = 4."
  m_isRightToLeft: 0
